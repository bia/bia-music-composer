# --- Training Configuration ---
# The model size to use ("3b" or "7b")
MODEL_SIZE=3b
# The run mode ("train" or "test")
RUN_MODE=train

# --- Few-shot fine-tuning ---
# "auto" = use real pairs if found, "yes" = require them, "no" = synthetic only
USE_REAL_AUDIO=auto
STYLE_TAGS=piano,ambient,reflective
STYLE_LOSS_WEIGHT=0.1
NUM_EPOCHS=3
LORA_RANK=16

# --- Google Cloud Configuration ---
PROJECT_ID=your-gcp-project-id
DOCKER_REGION=europe-west6
VM_ZONE=europe-west4-a

# GCS Storage (for model output and caching)
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_BUCKET_FOLDER_PREFIX=heartmula

# Paired training data
GCS_PAIRS_PATH=gs://your-gcs-bucket-name/data/paired
PAIRS_DIR=./data/paired

# Tag files (one per pair, named to match e.g. 001.txt → generated_001.wav)
GCS_TAGS_PATH=gs://your-gcs-bucket-name/data/paired/tags

# Docker image (set automatically by build_and_push.sh, or set manually)
DOCKER_IMAGE=europe-west6-docker.pkg.dev/your-gcp-project-id/heartmula-3b/heartmula-trainer:latest

# Generation settings
TEMPERATURE=1.0
CFG_SCALE=3.0

# --- audio2audio architecture settings ---
# Audio encoder model (MERT for music, WavLM for speech; 768d or 1024d depending on variant)
AUDIO_ENCODER_MODEL=m-a-p/MERT-v1-95M
# Number of conditioning prefix tokens injected into backbone (higher = more audio detail)
NUM_PREFIX_TOKENS=32
# Proxy candidates per input/output pair for training target scoring
NUM_PROXY_SAMPLES=3
# Input WAV for generate.py (GCS path or local path)
INPUT_WAV=gs://your-gcs-bucket-name/data/paired/inputs/my_input.wav
# Optional: GCS path to a pre-existing tags file (skips CLAP auto-annotation)
GCS_TAGS_FILE=gs://your-gcs-bucket-name/data/paired/tags/my_input.txt
